{
  "manifest_version": 3,
  "name": "LCA Sponsor Checker",
  "version": "1.5.1",
  "description": "Check if a LinkedIn company appears in DOL H-1B LCA disclosure data.",
  "permissions": ["storage"],
  "host_permissions": ["https://www.linkedin.com/*", "https://linkedin.com/*"],
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*", "https://linkedin.com/*"],
      "js": ["lib/matcher.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["data/employers.json.gz", "icons/rabbit.png"],
      "matches": ["https://www.linkedin.com/*", "https://linkedin.com/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
