# Copy to .env and adjust as needed. .env is gitignored.

# Postgres (used by docker-compose and the backend)
POSTGRES_USER=jobintel
POSTGRES_PASSWORD=jobintel
POSTGRES_DB=jobintel
# Host port. 5433 by default to avoid clashing with a local Postgres on 5432.
POSTGRES_PORT=5433

# Backend database connection
# Local (running scripts on host):     host is localhost, port matches POSTGRES_PORT
# In docker-compose (backend service): host is db, port 5432
DATABASE_URL=postgresql://jobintel:jobintel@localhost:5433/jobintel

# Backend HTTP port (host side)
BACKEND_PORT=8000

# LLM for JD parsing (OpenAI-compatible). Default targets OpenRouter's free tier.
# Get a key at https://openrouter.ai (Keys -> Create Key).
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-oss-20b:free

# Candidate intent profile (tracks, locations, …)
CANDIDATE_PROFILE_PATH=evals/golden_set/candidate_profile.yaml

# Dev default resume (when /analyze gets no resume_text; uploads override)
DEFAULT_RESUME_PATH=evals/golden_set/resume.md

# Resume RAG embeddings (OpenAI-compatible; uses same LLM_API_KEY / base URL)
EMBEDDING_MODEL=openai/text-embedding-3-small
